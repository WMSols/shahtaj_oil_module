<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shahtaj_oil.WarehouseInventory" owl="1">
        <div class="card border-0 shadow-sm bg-white rounded-3">
        
        <div class="p-4 border-bottom bg-light d-flex justify-content-between align-items-center rounded-top">
            <div>
                <h2 class="h4 fw-bold text-dark mb-0">Warehouse &amp; Inventory</h2>
                <small class="text-muted">Manage main hubs, sub-warehouses, and physical stock levels.</small>
            </div>
            <div>
                <span class="badge bg-dark px-3 py-2 text-white d-flex align-items-center shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-boxes me-2"><path d="M2.97 12.92A2 2 0 0 0 2 14.63v3.24a2 2 0 0 0 .97 1.71l3 1.8a2 2 0 0 0 2.06 0L12 19v-5.5l-5-3-4.03 2.42Z"/><path d="m7 16.5-4.74-2.85"/><path d="m7 16.5 5-3"/><path d="M7 16.5v5.17"/><path d="M12 13.5V19l3.97 2.38a2 2 0 0 0 2.06 0l3-1.8a2 2 0 0 0 .97-1.71v-3.24a2 2 0 0 0-.97-1.71L17 10.5l-5 3Z"/><path d="m17 16.5-5-3"/><path d="m17 16.5 4.74-2.85"/><path d="M17 16.5v5.17"/><path d="M7.97 4.42A2 2 0 0 0 7 6.13v4.37l5 3 5-3V6.13a2 2 0 0 0-.97-1.71l-3-1.8a2 2 0 0 0-2.06 0l-3 1.8Z"/><path d="M12 8 7.26 5.15"/><path d="m12 8 4.74-2.85"/><path d="M12 13.5V8"/></svg>
                    Inventory Engine Active
                </span>
            </div>
        </div>

        <div class="p-3 border-bottom">
            <ul class="nav nav-pills nav-fill">
                <li class="nav-item me-2">
                    <button t-on-click="() => this.setSubTab('inventory')" 
                            t-attf-class="nav-link fw-bold rounded-pill border-0 px-4 py-2 w-100 transition-all d-flex justify-content-center align-items-center #{this.state.activeSubTab === 'inventory' ? 'active bg-dark text-white shadow-sm' : 'text-muted bg-white'}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package me-2"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                        Stock Levels
                    </button>
                </li>
                <li class="nav-item me-2">
                    <button t-on-click="() => this.setSubTab('management')" 
                            t-attf-class="nav-link fw-bold rounded-pill border-0 px-4 py-2 w-100 transition-all d-flex justify-content-center align-items-center #{this.state.activeSubTab === 'management' ? 'active bg-dark text-white shadow-sm' : 'text-muted bg-white'}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clipboard-list me-2"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
                        Stock Management
                    </button>
                </li>
                <li class="nav-item">
                    <button t-on-click="() => this.setSubTab('warehouses')" 
                            t-attf-class="nav-link fw-bold rounded-pill border-0 px-4 py-2 w-100 transition-all d-flex justify-content-center align-items-center #{this.state.activeSubTab === 'warehouses' ? 'active bg-dark text-white shadow-sm' : 'text-muted bg-white'}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-factory me-2"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/></svg>
                        Facilities &amp; Hubs
                    </button>
                </li>
            </ul>
        </div>

        <t t-if="this.state.activeSubTab === 'inventory'">
            <div class="p-4 bg-white border-bottom d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Master Inventory Control</h6>
                <div>
                    <button class="btn btn-sm btn-dark fw-bold me-2" t-on-click="() => { this.resetForms(); this.state.showProductAddForm = true; }">
                        + New Product
                    </button>
                </div>
            </div>

            <t t-if="this.state.showProductAddForm">
                <div class="p-4 bg-light border-bottom rounded-3 m-3">
                    <h6 class="fw-bold text-dark mb-4">Create New Product</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="small fw-bold">Product Name</label>
                            <input type="text" class="form-control" t-model="this.state.productForm.name" placeholder="e.g. Cooking Oil 5L"/>
                        </div>
                        <div class="col-md-2">
                            <label class="small fw-bold">Product Type</label>
                            <select class="form-select" t-model="this.state.productForm.type">
                                <option value="consu">Goods</option>
                                <option value="service">Service</option>
                                <option value="combo">Combo</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="small fw-bold">Invoicing Policy</label>
                            <select class="form-select" t-model="this.state.productForm.invoice_policy">
                                <option value="order">Ordered Qty</option>
                                <option value="delivery">Delivered Qty</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end pb-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="trackInv" t-model="this.state.productForm.track_inventory"/>
                                <label class="form-check-label small fw-bold" for="trackInv">Track Inventory</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="small fw-bold">Initial On-Hand Qty</label>
                            <input type="number" class="form-control" t-model="this.state.productForm.on_hand" min="0" t-att-disabled="!this.state.productForm.track_inventory"/>
                        </div>

                        <div class="col-md-3">
                            <label class="small fw-bold">Sales Price</label>
                            <input type="number" class="form-control" t-model="this.state.productForm.list_price"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Selling Unit</label>
                            <select class="form-select" t-model="this.state.productForm.shahtaj_sale_uom"
                                    t-on-change="() => this.onSaleUomChange('new')">
                                <option value="kg">Kilogram (kg)</option>
                                <option value="ton">Ton</option>
                                <option value="litre">Litre</option>
                                <option value="piece">Piece</option>
                            </select>
                        </div>
                        <div class="col-md-3" t-if="this.state.productForm.shahtaj_sale_uom === 'litre' or this.state.productForm.shahtaj_sale_uom === 'piece'">
                            <label class="small fw-bold">Kg per Unit</label>
                            <input type="number" class="form-control" t-model="this.state.productForm.shahtaj_kg_per_unit" min="0.0001" step="0.0001"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Cost</label>
                            <input type="number" class="form-control" t-model="this.state.productForm.standard_price"/>
                        </div>
                        <div class="col-md-6">
                            <label class="small fw-bold">Customer Taxes</label>
                            <div class="border rounded p-2 bg-white">
                                <t t-if="this.state.saleTaxes.length === 0">
                                    <small class="text-muted">No sale taxes configured.</small>
                                </t>
                                <t t-foreach="this.state.saleTaxes" t-as="tax" t-key="tax.id">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               t-att-id="'new_tax_' + tax.id"
                                               t-att-checked="this.isTaxSelected('new', tax.id)"
                                               t-on-change="(ev) => this.toggleProductTax('new', tax.id, ev.target.checked)"/>
                                        <label class="form-check-label small" t-att-for="'new_tax_' + tax.id">
                                            <t t-esc="tax.label"/>
                                        </label>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Barcode</label>
                            <input type="text" class="form-control" t-model="this.state.productForm.barcode"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Image</label>
                            <input type="file" class="form-control form-control-sm mt-1" accept="image/*" t-on-change="(ev) => this.onImageChange(ev, 'new')"/>
                            <t t-if="this.state.productForm.image_1920">
                                <div class="mt-2 text-center">
                                    <img t-attf-src="data:image/jpeg;base64,{{this.state.productForm.image_1920}}" class="img-thumbnail" style="max-height: 80px;" />
                                </div>
                            </t>
                        </div>

                        <div class="col-md-3">
                            <label class="small fw-bold">Weight (kg)</label>
                            <input type="number" class="form-control" t-model="this.state.productForm.weight"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Volume (m³)</label>
                            <input type="number" class="form-control" t-model="this.state.productForm.volume"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Income Account</label>
                            <select class="form-select" t-model="this.state.productForm.income_account">
                                <option value="static_inc">Default Income Account</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Expense Account</label>
                            <select class="form-select" t-model="this.state.productForm.expense_account">
                                <option value="static_exp">Default Expense Account</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="mt-4 d-flex justify-content-end">
                        <button class="btn btn-outline-secondary me-2 fw-bold" t-on-click="() => this.state.showProductAddForm = false">Cancel</button>
                        <button class="btn btn-success fw-bold text-white px-4" t-on-click="saveProduct">Save Product</button>
                    </div>
                </div>
            </t>

            <t t-if="this.state.showProductDetails">
                <div class="p-4 m-3 border rounded-3 bg-white shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Edit Details: <t t-esc="this.state.currentProduct.name"/></h5>
                        <button class="btn btn-sm btn-close" t-on-click="() => this.state.showProductDetails = false"></button>
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="small fw-bold">Product Name</label>
                            <input type="text" class="form-control" t-model="this.state.currentProduct.name"/>
                        </div>
                        
                        <div class="col-md-6 d-flex align-items-start">
                            <div class="me-3">
                                <t t-if="this.state.currentProduct.image_1920">
                                    <img t-attf-src="data:image/jpeg;base64,{{this.state.currentProduct.image_1920}}" class="img-thumbnail rounded" style="max-width: 80px; max-height: 80px; object-fit: cover;"/>
                                </t>
                                <t t-else="">
                                    <div class="border rounded d-flex justify-content-center align-items-center bg-light text-muted" style="width: 80px; height: 80px;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                                    </div>
                                </t>
                            </div>
                            <div class="flex-grow-1">
                                <label class="small fw-bold">Update Image</label>
                                <input type="file" class="form-control form-control-sm" accept="image/*" t-on-change="(ev) => this.onImageChange(ev, 'edit')"/>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="small fw-bold">Sales Price</label>
                            <input type="number" class="form-control" t-model="this.state.currentProduct.list_price"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Selling Unit</label>
                            <select class="form-select" t-model="this.state.currentProduct.shahtaj_sale_uom"
                                    t-on-change="() => this.onSaleUomChange('edit')">
                                <option value="kg">Kilogram (kg)</option>
                                <option value="ton">Ton</option>
                                <option value="litre">Litre</option>
                                <option value="piece">Piece</option>
                            </select>
                        </div>
                        <div class="col-md-3" t-if="this.state.currentProduct.shahtaj_sale_uom === 'litre' or this.state.currentProduct.shahtaj_sale_uom === 'piece'">
                            <label class="small fw-bold">Kg per Unit</label>
                            <input type="number" class="form-control" t-model="this.state.currentProduct.shahtaj_kg_per_unit" min="0.0001" step="0.0001"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Cost</label>
                            <input type="number" class="form-control" t-model="this.state.currentProduct.standard_price"/>
                        </div>
                        <div class="col-md-6">
                            <label class="small fw-bold">Customer Taxes</label>
                            <div class="border rounded p-2 bg-white">
                                <t t-if="this.state.saleTaxes.length === 0">
                                    <small class="text-muted">No sale taxes configured.</small>
                                </t>
                                <t t-foreach="this.state.saleTaxes" t-as="tax" t-key="tax.id">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               t-att-id="'edit_tax_' + tax.id"
                                               t-att-checked="this.isTaxSelected('edit', tax.id)"
                                               t-on-change="(ev) => this.toggleProductTax('edit', tax.id, ev.target.checked)"/>
                                        <label class="form-check-label small" t-att-for="'edit_tax_' + tax.id">
                                            <t t-esc="tax.label"/>
                                        </label>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Barcode</label>
                            <input type="text" class="form-control" t-model="this.state.currentProduct.barcode"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Weight (kg)</label>
                            <input type="number" class="form-control" t-model="this.state.currentProduct.weight"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold">Volume (m³)</label>
                            <input type="number" class="form-control" t-model="this.state.currentProduct.volume"/>
                        </div>
                    </div>
                    
                    <div class="mt-4 text-end">
                        <button class="btn btn-primary fw-bold px-4" t-on-click="updateProduct">Save Changes</button>
                    </div>
                </div>
            </t>

            <t t-if="!this.state.showProductDetails">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-light text-uppercase small fw-bold text-muted">
                            <tr>
                                <th class="border-top-0 ps-4">Product Details</th>
                                <th class="border-top-0">Barcode</th>
                                <th class="border-top-0 text-end">Price / Cost</th>
                                <th class="border-top-0 text-end">On-Hand Qty</th>
                                <th class="border-top-0 text-center pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="this.state.inventory" t-as="item" t-key="item.id">
                                <tr>
                                    <td class="ps-4 d-flex align-items-center">
                                        <t t-if="item.image_1920">
                                            <img t-attf-src="data:image/jpeg;base64,{{item.image_1920}}" class="rounded me-3 shadow-sm" style="width: 40px; height: 40px; object-fit: cover;" />
                                        </t>
                                        <t t-else="">
                                            <div class="rounded me-3 d-flex justify-content-center align-items-center bg-light text-muted border shadow-sm" style="width: 40px; height: 40px;">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-box"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                                            </div>
                                        </t>
                                        <div>
                                            <div class="text-dark fw-bold"><t t-esc="item.name"/></div>
                                            <small class="text-muted">Unit: <t t-esc="item.shahtaj_sale_uom || item.uom_name"/> · Tax: <t t-esc="item.tax_label"/> · Type: <t t-esc="item.type === 'consu' or item.type === 'product' ? 'Goods' : item.type"/></small>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-muted small"><t t-esc="item.barcode || 'N/A'"/></span>
                                    </td>
                                    <td class="text-end">
                                        <div class="fw-bold"><t t-esc="item.list_price"/></div>
                                        <small class="text-muted"><t t-esc="item.standard_price"/></small>
                                    </td>
                                    <td class="text-end">
                                        <span class="h6 fw-bold text-dark mb-0"><t t-esc="item.qty_available"/></span>
                                        <span class="text-muted ms-1 small"><t t-esc="item.uom_name"/></span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <button class="btn btn-sm btn-light border fw-bold text-primary" t-on-click="() => this.viewProductDetails(item)">
                                            View Details
                                        </button>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>

        <t t-if="this.state.activeSubTab === 'management'">
            <div class="p-4 bg-white border-bottom d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0 text-dark">Stock Management Overview</h6>
                <button class="btn btn-sm btn-dark fw-bold shadow-sm" t-on-click="() => this.state.showAdjustmentForm = !this.state.showAdjustmentForm">
                    <t t-if="!this.state.showAdjustmentForm">+ Update Stock</t>
                    <t t-else="">Close Stock Update</t>
                </button>
            </div>

            <t t-if="this.state.showAdjustmentForm">
                <div class="p-4 bg-light border-bottom border-top">
                    <div class="row align-items-end g-3">
                        <div class="col-md-4">
                            <label class="small fw-bold">Select Product</label>
                            <select class="form-select shadow-sm" t-model="this.state.adjustmentForm.product_id">
                                <option value="">-- Choose SKU --</option>
                                <t t-foreach="this.state.inventory" t-as="inv" t-key="inv.id">
                                    <option t-att-value="inv.id"><t t-esc="inv.name"/></option>
                                </t>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="small fw-bold text-muted">Current On-Hand</label>
                            <input type="text" class="form-control bg-white shadow-sm" t-att-value="this.selectedProductStock" disabled="1"/>
                        </div>
                        <div class="col-md-3">
                            <label class="small fw-bold text-success">Quantity to Add</label>
                            <input type="number" class="form-control border-success shadow-sm" t-model="this.state.adjustmentForm.qty" min="1"/>
                        </div>
                        <div class="col-md-3 d-flex pb-1">
                            <button class="btn btn-outline-secondary w-50 me-2 fw-bold" t-on-click="() => { this.state.showAdjustmentForm = false; this.state.adjustmentForm = { product_id: '', qty: 0 }; }">Cancel</button>
                            <button class="btn btn-success w-50 fw-bold text-white shadow-sm" t-on-click="saveAdjustment">Apply</button>
                        </div>
                    </div>
                </div>
            </t>

            <div class="table-responsive p-0 bg-white">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-uppercase small fw-bold text-muted">
                        <tr>
                            <th class="border-top-0 ps-4 py-3">Product Name</th>
                            <th class="border-top-0 py-3 text-end">On-Hand Qty</th>
                            <th class="border-top-0 py-3 text-end">Available to Book</th>
                            <th class="border-top-0 py-3 text-end">Forecast</th>
                            <th class="border-top-0 py-3 text-end pe-4">Unit Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="this.state.inventory" t-as="item" t-key="item.id">
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    <t t-esc="item.name"/>
                                </td>
                                <td class="text-end fw-bold">
                                    <t t-esc="item.qty_available || 0"/> <span class="text-muted small ms-1"><t t-esc="item.uom_name"/></span>
                                </td>
                                <td class="text-end text-primary fw-bold">
                                    <t t-esc="item.shahtaj_qty_bookable || 0"/> <span class="text-muted small ms-1"><t t-esc="item.uom_name"/></span>
                                </td>
                                <td class="text-end text-success fw-bold">
                                    <t t-esc="item.virtual_available || 0"/> <span class="text-muted small ms-1"><t t-esc="item.uom_name"/></span>
                                </td>
                                <td class="text-end pe-4 text-muted fw-bold">
                                    <t t-esc="item.list_price"/>
                                </td>
                            </tr>
                        </t>
                        <t t-if="this.state.inventory.length === 0">
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search mb-2 opacity-50"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                                    <p class="mb-0">No products found in inventory.</p>
                                </td>
                            </tr>
