<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shahtaj_oil.FinancialsInvoicing" owl="1">
      <div class="card border-0 shadow-sm bg-white rounded-3">
        
        <div class="p-4 border-bottom bg-light d-flex justify-content-between align-items-center rounded-top">
            <div>
                <h2 class="h4 fw-bold text-dark mb-0">Financials &amp; Invoicing</h2>
                <small class="text-muted">Manage field billing, collections, and shop ledger balances.</small>
            </div>
        </div>

        <!-- MAIN SUB-NAVIGATION -->
        <div class="p-3 border-bottom">
            <ul class="nav nav-pills nav-fill">
                <li class="nav-item me-2">
                    <button t-on-click="() => this.setSubTab('invoices')" 
                            t-attf-class="nav-link fw-bold rounded-pill border-0 px-4 py-2 w-100 transition-all #{this.state.activeSubTab === 'invoices' ? 'active bg-dark text-white shadow-sm' : 'text-muted bg-white'}">
                        Invoice Management
                    </button>
                </li>
                <li class="nav-item">
                    <button t-on-click="() => this.setSubTab('credit')" 
                            t-attf-class="nav-link fw-bold rounded-pill border-0 px-4 py-2 w-100 transition-all #{this.state.activeSubTab === 'credit' ? 'active bg-dark text-white shadow-sm' : 'text-muted bg-white'}">
                        Credit Risk Control
                    </button>
                </li>
            </ul>
        </div>

        <!-- ========================================== -->
        <!-- TAB 1: INVOICE MANAGEMENT                  -->
        <!-- ========================================== -->
        <t t-if="this.state.activeSubTab === 'invoices'">
            <div class="px-4 pt-3 bg-white border-bottom shadow-sm">
                <ul class="nav nav-tabs border-0">
                    <li class="nav-item me-4">
                        <button t-on-click="() => this.setInvoiceSubTab('orders')" t-attf-class="nav-link bg-transparent border-0 fw-bold pb-2 fs-6 #{this.state.invoiceSubTab === 'orders' ? 'text-primary border-bottom border-primary border-3 rounded-0' : 'text-muted'}">
                            <i class="fa fa-shopping-cart me-1"></i> Orders to Invoice
                        </button>
                    </li>
                    <li class="nav-item me-4">
                        <button t-on-click="() => this.setInvoiceSubTab('customer_invoices')" t-attf-class="nav-link bg-transparent border-0 fw-bold pb-2 fs-6 #{this.state.invoiceSubTab === 'customer_invoices' ? 'text-primary border-bottom border-primary border-3 rounded-0' : 'text-muted'}">
                            <i class="fa fa-file-text-o me-1"></i> Customer Invoices
                        </button>
                    </li>
                    <li class="nav-item me-4">
                        <button t-on-click="() => this.setInvoiceSubTab('payments')" t-attf-class="nav-link bg-transparent border-0 fw-bold pb-2 fs-6 #{this.state.invoiceSubTab === 'payments' ? 'text-primary border-bottom border-primary border-3 rounded-0' : 'text-muted'}">
                            <i class="fa fa-money me-1"></i> Customer Payments
                        </button>
                    </li>
                    <li class="nav-item">
                        <button t-on-click="() => this.setInvoiceSubTab('balances')" t-attf-class="nav-link bg-transparent border-0 fw-bold pb-2 fs-6 #{this.state.invoiceSubTab === 'balances' ? 'text-primary border-bottom border-primary border-3 rounded-0' : 'text-muted'}">
                            <i class="fa fa-balance-scale me-1"></i> Shop Balances
                        </button>
                    </li>
                </ul>
            </div>

            <!-- FEATURE 1: ORDERS TO INVOICE -->
           <t t-if="this.state.invoiceSubTab === 'orders'">
            <t t-if="!this.state.selectedOrder">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-uppercase small fw-bold text-muted">
                            <tr>
                                <th class="ps-4 py-3">Order Ref #</th>
                                <th>Shop Name</th>
                                <th>Order Booker</th>
                                <th>Order Date</th>
                                <th class="text-end">Total Amount</th>
                                <th class="text-end pe-4">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="this.state.orders.length === 0">
                                <tr><td colspan="6" class="text-center py-5 text-muted fw-bold">No confirmed orders pending invoice.</td></tr>
                            </t>
                            <t t-foreach="this.state.orders" t-as="ord" t-key="ord.id">
                                <tr>
                                    <td class="ps-4 fw-bold text-primary"><t t-esc="ord.display_name"/></td>
                                    <td class="fw-bold">
                                        <t t-esc="ord.shop"/>
                                        <small class="d-block text-muted fw-normal">Shop ID: <t t-esc="ord.shopId"/></small>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary"><i class="fa fa-user me-1"></i> <t t-esc="ord.booker"/></span>
                                        <small class="d-block text-muted mt-1">Booker ID: <t t-esc="ord.bookerId"/></small>
                                    </td>
                                    <td class="text-muted"><t t-esc="ord.date"/></td>
                                    <td class="text-end fw-bold text-dark">Rs. <t t-esc="ord.amount"/></td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-sm btn-dark fw-bold px-3" t-on-click="() => this.viewOrder(ord)">View &amp; Invoice</button>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
            <t t-else="">
                <div class="p-4 bg-light">
                    <div class="d-flex justify-content-between mb-4">
                        <button class="btn btn-sm btn-light border fw-bold px-3 shadow-sm" t-on-click="() => this.state.selectedOrder = null">
                            <i class="fa fa-arrow-left me-1"></i> Back to Orders
                        </button>
                        <button class="btn btn-primary fw-bold text-white shadow-sm px-4" t-on-click="() => this.triggerCreateInvoice(this.state.selectedOrder)">
                            <i class="fa fa-file-text me-1"></i> Generate Draft Invoice
                        </button>
                    </div>
                    
                    <div class="card p-0 shadow-sm border-0 border-start border-4 border-primary overflow-hidden">
                        <div class="p-4 border-bottom bg-white">
                            <h4 class="mb-4 text-dark fw-bold">Order Details: <t t-esc="this.state.selectedOrder.display_name"/></h4>
                            <div class="row gx-4 gy-3">
                                <div class="col-md-4">
                                    <div class="small text-muted fw-bold text-uppercase mb-1">Customer / Shop</div>
                                    <div class="fw-bold text-dark fs-6"><t t-esc="this.state.selectedOrder.shop"/></div>
                                    <small class="text-muted">Shop ID: <t t-esc="this.state.selectedOrder.shopId"/></small>
                                </div>
                                <div class="col-md-4">
                                    <div class="small text-muted fw-bold text-uppercase mb-1">Order Booker</div>
                                    <div class="fw-bold text-dark fs-6"><t t-esc="this.state.selectedOrder.booker"/></div>
                                    <small class="text-muted">Booker ID: <t t-esc="this.state.selectedOrder.bookerId"/></small>
                                </div>
                                <div class="col-md-4">
                                    <div class="small text-muted fw-bold text-uppercase mb-1">Order Date</div>
                                    <div class="text-dark fs-6"><t t-esc="this.state.selectedOrder.date"/></div>
                                </div>
                                <div class="col-md-4">
                                    <div class="small text-muted fw-bold text-uppercase mb-1">Associated Visit Task</div>
                                    <div class="text-primary fw-bold small"><t t-esc="this.state.selectedOrder.visit"/></div>
                                </div>
                                <div class="col-md-4">
                                    <div class="small text-muted fw-bold text-uppercase mb-1">Payment Terms</div>
                                    <div class="text-dark fs-6"><t t-esc="this.state.selectedOrder.paymentTerms"/></div>
                                </div>
                                <div class="col-md-4">
                                    <div class="small text-muted fw-bold text-uppercase mb-1">Pricelist</div>
                                    <div class="text-dark fs-6"><t t-esc="this.state.selectedOrder.pricelist"/></div>
                                </div>
                            </div>
                        </div>

                        <div class="p-0 bg-white">
                            <table class="table table-hover align-middle mb-0 border-bottom">
                                <thead class="bg-light text-muted small fw-bold">
                                    <tr>
                                        <th class="ps-4">Product</th>
                                        <th class="text-center">Ordered</th>
                                        <th class="text-center">Delivered</th>
                                        <th class="text-center">Invoiced</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end pe-4">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="this.state.selectedOrderLines.length === 0">
                                        <tr><td colspan="6" class="text-center py-4 text-muted"><i class="fa fa-circle-o-notch fa-spin me-2"></i> Loading Order Lines...</td></tr>
                                    </t>
                                    <t t-foreach="this.state.selectedOrderLines" t-as="line" t-key="line.id">
                                        <tr>
                                            <td class="ps-4 fw-bold text-dark"><t t-esc="line.product"/></td>
                                            <td class="text-center text-primary fw-bold"><t t-esc="line.qty"/></td>
                                            <td class="text-center"><t t-esc="line.delivered"/></td>
                                            <td class="text-center"><t t-esc="line.invoiced"/></td>
                                            <td class="text-end text-muted">Rs. <t t-esc="line.price"/></td>
                                            <td class="text-end fw-bold text-dark pe-4">Rs. <t t-esc="line.subtotal"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <div class="p-4 bg-light text-end">
                            <div class="row justify-content-end">
                                <div class="col-md-5 col-lg-4">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted fw-bold text-uppercase small">Untaxed Amount:</span>
                                        <span class="fw-bold text-dark">Rs. <t t-esc="this.state.selectedOrder.untaxedAmount"/></span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-2 border-secondary">
                                        <span class="text-dark fw-bold text-uppercase">Total:</span>
                                        <h3 class="text-success fw-bold mb-0">Rs. <t t-esc="this.state.selectedOrder.amount"/></h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>

            <!-- FEATURE 2: CUSTOMER INVOICES -->
            <t t-if="this.state.invoiceSubTab === 'customer_invoices'">
                <t t-if="!this.state.selectedInvoice">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-uppercase small fw-bold text-muted">
                                <tr>
                                    <th class="ps-4 py-3">Invoice #</th>
                                    <th>Billed Shop</th>
                                    <th>Date</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-center pe-4">Billing Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="this.state.invoices.length === 0">
                                    <tr><td colspan="5" class="text-center py-5 text-muted fw-bold">No generated invoices found.</td></tr>
                                </t>
                                <t t-foreach="this.state.invoices" t-as="inv" t-key="inv.id">
                                    <tr style="cursor:pointer;" class="transition-all" t-on-click="() => this.viewInvoice(inv)">
                                        <td class="ps-4 fw-bold text-primary"><t t-esc="inv.display_name"/></td>
                                        <td class="fw-bold"><t t-esc="inv.shop"/></td>
                                        <td><t t-esc="inv.date"/></td>
                                        <td class="text-end fw-bold">Rs. <t t-esc="inv.amount"/></td>
                                        <td class="text-center pe-4">
                                            <span t-attf-class="badge text-white #{inv.status === 'Paid' ? 'bg-success' : inv.status === 'Posted' ? 'bg-info ' : 'bg-secondary'} px-2 py-1 shadow-sm">
                                                <t t-esc="inv.status"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
                <t t-else="">
                    <div class="p-4 bg-light">
                        <div class="d-flex justify-content-between mb-4">
                            <button class="btn btn-sm btn-light border fw-bold px-3 shadow-sm" t-on-click="() => this.state.selectedInvoice = null">
                                <i class="fa fa-arrow-left me-1"></i> Back to Invoices
                            </button>
                            <div class="d-flex gap-2">
                                <button t-if="this.state.selectedInvoice.status !== 'Draft'" class="btn btn-outline-dark fw-bold px-3 bg-white" t-on-click="() => this.actionPrintInvoice(this.state.selectedInvoice.id)">
                                    <i class="fa fa-print me-1"></i> Print PDF
                                </button>
                                <button t-if="this.state.selectedInvoice.status !== 'Draft' and this.state.selectedInvoice.status !== 'Paid'" class="btn btn-warning fw-bold text-dark px-3" t-on-click="() => this.actionResetToDraft(this.state.selectedInvoice)">
                                    <i class="fa fa-undo me-1"></i> Reset to Draft
                                </button>
                                <button t-if="this.state.selectedInvoice.status === 'Draft'" class="btn btn-primary fw-bold text-white px-3" t-on-click="() => this.actionConfirmInvoice(this.state.selectedInvoice)">
                                    <i class="fa fa-check me-1"></i> Confirm Invoice
                                </button>
                                <button t-elif="this.state.selectedInvoice.status === 'Posted'" class="btn btn-success fw-bold text-white px-4 shadow-sm" t-on-click="openPaymentModal">
                                    <i class="fa fa-money me-1"></i> Register Payment
                                </button>
                            </div>
                        </div>
                        <div class="card p-4 shadow-sm border-0 border-start border-4 border-info">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="text-dark fw-bold mb-0">Invoice: <t t-esc="this.state.selectedInvoice.display_name"/></h4>
                                <span t-attf-class="badge fs-6 #{this.state.selectedInvoice.status === 'Paid' ? 'bg-success' : this.state.selectedInvoice.status === 'Posted' ? 'bg-info ' : 'bg-secondary'} px-3 py-2 text-white shadow-sm">
                                    <t t-esc="this.state.selectedInvoice.status"/>
                                </span>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-2"><span class="text-muted fw-bold">Billed To:</span> <span class="fw-bold ms-2"><t t-esc="this.state.selectedInvoice.shop"/></span></div>
                                <div class="col-md-6 mb-2"><span class="text-muted fw-bold">Date:</span> <span class="fw-bold ms-2"><t t-esc="this.state.selectedInvoice.date"/></span></div>
                                <div class="col-md-12 mt-3"><h3 class="text-dark fw-bold">Amount: Rs. <t t-esc="this.state.selectedInvoice.amount"/></h3></div>
                            </div>
                        </div>
                    </div>

                    <!-- PAYMENT WIZARD MODAL -->
                    <t t-if="this.state.showPaymentModal">
                        <div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center" style="background-color: rgba(0, 0, 0, 0.6); z-index: 1050;">
                            <div class="bg-white p-4 rounded-3 shadow-lg" style="width: 500px;">
                                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                                    <h5 class="fw-bold text-dark mb-0"><i class="fa fa-money text-success me-2"></i> Register Payment</h5>
                                </div>
                                
                                <div class="mb-3">
                                    <label class="small fw-bold text-muted">Linking to Invoice</label>
                                    <input type="text" class="form-control bg-light fw-bold text-primary" t-att-value="this.state.paymentForm.invoice_name" disabled="1"/>
                                </div>
                                
                                <div class="row">
                                    <div class="col-6 mb-3">
                                        <label class="small fw-bold">Payment Amount (Rs.)</label>
                                        <input type="number" class="form-control fw-bold text-success" t-model="this.state.paymentForm.amount"/>
                                    </div>
                                    <div class="col-6 mb-3">
                                        <label class="small fw-bold">Payment Date</label>
                                        <input type="date" class="form-control" t-model="this.state.paymentForm.date"/>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="small fw-bold">Deposit Journal (Bank/Cash)</label>
                                    <select class="form-select form-control" t-model="this.state.paymentForm.journal_id">
                                        <t t-foreach="this.state.journals" t-as="j" t-key="j.id">
                                            <option t-att-value="j.id"><t t-esc="j.name"/></option>
                                        </t>
                                    </select>
                                </div>

                                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                                    <button class="btn btn-light fw-bold border px-4" t-on-click="closePaymentModal">Cancel</button>
                                    <button class="btn btn-success fw-bold text-white px-4 shadow-sm" t-on-click="processPayment">Validate &amp; Pay</button>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>

            <!-- FEATURE 3: CUSTOMER PAYMENTS -->
            <t t-if="this.state.invoiceSubTab === 'payments'">
                <t t-if="!this.state.selectedPayment">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-uppercase small fw-bold text-muted">
                                <tr>
                                    <th class="ps-4 py-3">Receipt #</th>
                                    <th>Paid By Shop</th>
                                    <th>Journal / Bank</th>
                                    <th>Ref / Memo</th>
                                    <th class="text-end pe-4">Received Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="this.state.payments.length === 0">
                                    <tr><td colspan="5" class="text-center py-5 text-muted fw-bold">No registered payments found.</td></tr>
                                </t>
                                <t t-foreach="this.state.payments" t-as="pay" t-key="pay.id">
                                    <tr style="cursor:pointer;" class="transition-all" t-on-click="() => this.viewPayment(pay)">
                                        <td class="ps-4 fw-bold text-success"><t t-esc="pay.display_name"/></td>
                                        <td class="fw-bold"><t t-esc="pay.shop"/></td>
                                        <td><span class="badge bg-light text-dark border shadow-sm"><i class="fa fa-bank me-1"></i> <t t-esc="pay.method"/></span></td>
                                        <td class="text-muted"><t t-esc="pay.ref"/></td>
                                        <td class="text-end fw-bold pe-4">Rs. <t t-esc="pay.amount"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
                <t t-else="">
                    <div class="p-4 bg-light">
                        <button class="btn btn-sm btn-light border fw-bold px-3 shadow-sm mb-4" t-on-click="() => this.state.selectedPayment = null">
                            <i class="fa fa-arrow-left me-1"></i> Back to Payment Log
                        </button>
                        <div class="card p-4 shadow-sm border-0 border-start border-4 border-success">
                            <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-3">
                                <h4 class="text-dark fw-bold mb-0">Payment Receipt: <t t-esc="this.state.selectedPayment.display_name"/></h4>
                                <span class="badge bg-success text-white px-3 py-2 shadow-sm fs-6"><t t-esc="this.state.selectedPayment.status"/></span>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3"><span class="text-muted fw-bold">Customer Shop:</span> <span class="fw-bold ms-2 text-dark fs-5"><t t-esc="this.state.selectedPayment.shop"/></span></div>
                                <div class="col-md-6 mb-3"><span class="text-muted fw-bold">Date Received:</span> <span class="fw-bold ms-2"><t t-esc="this.state.selectedPayment.date"/></span></div>
                                <div class="col-md-6 mb-3"><span class="text-muted fw-bold">Deposited Into:</span> <span class="fw-bold ms-2"><t t-esc="this.state.selectedPayment.method"/></span></div>
                                <div class="col-md-6 mb-3"><span class="text-muted fw-bold">Invoice Ref:</span> <span class="fw-bold ms-2"><t t-esc="this.state.selectedPayment.ref"/></span></div>
                                <div class="col-md-12 mt-4 pt-3 border-top"><h2 class="text-success fw-bold mb-0">Total Received: Rs. <t t-esc="this.state.selectedPayment.amount"/></h2></div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>

            <!-- FEATURE 4: SHOP BALANCES -->
            <t t-if="this.state.invoiceSubTab === 'balances'">
                <t t-if="!this.state.selectedShop">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-uppercase small fw-bold text-muted">
                                <tr>
                                    <th class="ps-4 py-3">Shop Name</th>
                                    <th>Shop Owner</th>
                                    <th>Assigned Route</th>
                                    <th class="text-end">Credit Limit</th>
                                    <th class="text-end pe-4">Outstanding (Receivable)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="this.state.balances.length === 0">
                                    <tr><td colspan="5" class="text-center py-5 text-muted fw-bold">No approved shops found.</td></tr>
                                </t>
                                <t t-foreach="this.state.balances" t-as="bal" t-key="bal.id">
                                    <tr style="cursor:pointer;" class="transition-all" t-on-click="() => this.viewShop(bal)">
                                        <td class="ps-4 fw-bold text-dark">
                                            <t t-esc="bal.shop"/>
                                            <small class="d-block text-muted fw-normal">Shop ID: <t t-esc="bal.shopId"/></small>
                                        </td>
                                        <td><t t-esc="bal.owner"/></td>
                                        <td><span class="badge bg-secondary"><t t-esc="bal.route"/></span></td>
                                        <td class="text-end fw-bold">Rs. <t t-esc="bal.limit"/></td>
                                        <td class="text-end text-danger fw-bold pe-4">Rs. <t t-esc="bal.outstanding"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
                <t t-else="">
                    <div class="p-4 bg-light">
                        <button class="btn btn-sm btn-light border fw-bold px-3 shadow-sm mb-4" t-on-click="() => this.state.selectedShop = null">
                            <i class="fa fa-arrow-left me-1"></i> Back to Ledger
                        </button>
                        <div class="card p-4 shadow-sm border-0 border-start border-4 border-warning">
                            <h4 class="mb-1 text-dark fw-bold">
                                <t t-esc="this.state.selectedShop.shop"/>
                            </h4>
                            <p class="text-muted small mb-4">Shop ID: <t t-esc="this.state.selectedShop.shopId"/></p>
                            <div class="row align-items-center border-bottom pb-4 mb-4">
                                <div class="col-md-6 border-end">
                                    <label class="small fw-bold text-muted">Shop Owner</label>
                                    <h5 class="text-dark fw-bold mb-0"><t t-esc="this.state.selectedShop.owner"/></h5>
                                </div>
                                <div class="col-md-6 ps-4">
                                    <label class="small fw-bold text-muted">Current Outstanding (Receivable)</label>
                                    <h3 class="text-danger fw-bold mb-0">Rs. <t t-esc="this.state.selectedShop.outstanding"/></h3>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <label class="small fw-bold text-dark mb-2">Approved Credit Limit (Rs.)</label>
                                    <div class="input-group input-group-lg shadow-sm">
                                        <span class="input-group-text bg-white border-end-0 fw-bold text-muted">Rs.</span>
                                        <input type="number" class="form-control border-start-0 fw-bold" t-model="this.state.selectedShop.rawLimit"/>
                                    </div>
                                    <small class="text-muted d-block mt-2">Adjusting this will allow/prevent the booker from finalizing orders beyond this amount.</small>
                                </div>
                                <div class="col-md-12 mt-4 text-end">
                                    <button class="btn btn-dark fw-bold text-white px-5 shadow-sm" t-on-click="saveShopBalance">
                                        <i class="fa fa-save me-1"></i> Save Credit Limit
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>

        <!-- ========================================== -->
        <!-- TAB 2: CREDIT RISK CONTROL (Restored!)     -->
        <!-- ========================================== -->
        <t t-if="this.state.activeSubTab === 'credit'">
            <div class="p-4 bg-white border-bottom d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Shop Credit Limit Monitor</h6>
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-uppercase small fw-bold text-muted">
                        <tr>
                            <th class="border-top-0 ps-4 py-3">Shop Details</th>
                            <th class="border-top-0 w-25">Credit Utilization</th>
                            <th class="border-top-0 text-end">Available Credit</th>
                            <th class="border-top-0 text-center pe-4">Risk Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-if="this.state.credits.length === 0">
                            <tr><td colspan="4" class="text-center py-5 text-muted fw-bold">No shops available for credit monitoring.</td></tr>
                        </t>
                        <t t-foreach="this.state.credits" t-as="credit" t-key="credit.id">
                            <tr>
                                <td class="ps-4">
                                    <div class="text-dark fw-bold"><t t-esc="credit.shop"/></div>
                                    <small class="text-muted">Shop ID: <t t-esc="credit.shopId || credit.id"/></small>
                                </td>
                                <td>
                                    <div class="d-flex justify-content-between mb-1">
                                        <small class="fw-bold text-dark">Rs. <t t-esc="credit.utilized"/></small>
                                        <small class="text-muted">Limit: Rs. <t t-esc="credit.limit"/></small>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <!-- Safely calculate the width percentage using raw numerical values -->
                                        <div t-attf-class="progress-bar #{credit.status === 'Healthy' ? 'bg-success' : credit.status === 'Critical' ? 'bg-warning' : 'bg-danger'}" 
                                             role="progressbar" 
                                             t-attf-style="width: #{credit.rawLimit > 0 ? (credit.rawUtilized / credit.rawLimit) * 100 : 0}%; max-width: 100%;"></div>
                                    </div>
                                </td>
                                <td class="text-end fw-bold">
                                    Rs. <t t-esc="credit.available"/>
                                </td>
                                <td class="text-center pe-4">
                                    <span t-attf-class="badge #{credit.status === 'Healthy' ? 'bg-success text-white' : credit.status === 'Critical' ? 'bg-warning text-dark' : 'bg-danger text-white'} px-3 py-1 shadow-sm">
                                        <t t-esc="credit.status"/>
                                    </span>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
      </div>
    </t>
</templates>