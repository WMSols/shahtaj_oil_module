<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ir_cron_shahtaj_auto_generate_tasks" model="ir.cron">
        <field name="name">Shahtaj: Auto-generate visit tasks</field>
        <field name="model_id" ref="model_shahtaj_visit_task"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_generate_visit_tasks()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_shahtaj_close_stale_visits" model="ir.cron">
        <field name="name">Shahtaj: Close incomplete overnight visits</field>
        <field name="model_id" ref="model_shahtaj_visit"/>
        <field name="state">code</field>
        <field name="code">model._cron_close_stale_visits()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_shahtaj_refresh_booker_presence" model="ir.cron">
        <field name="name">Shahtaj: Refresh order booker online status</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">model._cron_refresh_order_booker_presence()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
