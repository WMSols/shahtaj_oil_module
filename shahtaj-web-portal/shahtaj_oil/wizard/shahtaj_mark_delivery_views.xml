<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_mark_delivery_wizard_form" model="ir.ui.view">
        <field name="name">shahtaj.mark.delivery.wizard.form</field>
        <field name="model">shahtaj.mark.delivery.wizard</field>
        <field name="arch" type="xml">
            <form string="Mark Delivery">
                <group>
                    <group>
                        <field name="sale_order_id"/>
                        <field name="partner_id"/>
                    </group>
                </group>
                <div class="alert alert-info" role="alert">
                    Set <b>Deliver Now</b> for each product (full or partial).
                    Stock on hand will decrease and the sales order
                    <b>Delivered</b> quantity will update.
                    With invoice policy <b>Delivered quantities</b>,
                    <b>Orders to Invoice</b> will then only allow billing what was delivered.
                </div>
                <field name="line_ids">
                    <list editable="bottom" create="false" delete="false">
                        <field name="move_id" column_invisible="1" force_save="1"/>
                        <field name="sale_line_id" column_invisible="1" force_save="1"/>
                        <field name="product_id" readonly="1"/>
                        <field name="qty_ordered" readonly="1" force_save="1"/>
                        <field name="qty_already_delivered" readonly="1" force_save="1"/>
                        <field name="qty_to_deliver" force_save="1"/>
                        <field name="product_uom_id" readonly="1"/>
                    </list>
                </field>
                <footer>
                    <button name="action_deliver_all_remaining" type="object"
                            string="Deliver All Remaining" class="btn-primary"/>
                    <button name="action_confirm_delivery" type="object"
                            string="Confirm Delivery" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_shahtaj_mark_delivery_wizard" model="ir.actions.act_window">
        <field name="name">Mark Delivery</field>
        <field name="res_model">shahtaj.mark.delivery.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_view_types">form</field>
    </record>

</odoo>
