<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shahtaj_oil.DashboardViewTemplate" owl="1">
        <div class="d-flex w-100 h-100 bg-light" style="min-height: 85vh;">

            <div class="bg-white border-end shadow-sm" style="width: 280px; min-width: 280px;">

                <div class="p-4 border-bottom text-center bg-white">
                    <img src="/web/binary/company_logo" alt="Shahtaj Oil Logo" style="max-height: 120px; width: 100%; object-fit: contain;" class="mb-2"/>
                    <h6 class="mb-0 fw-bold text-dark mt-2">Distributor Portal</h6>
                </div>

                <div class="list-group list-group-flush p-3 fw-bold">

                    <button t-on-click="() => this.switchTab('dashboard')" class="list-group-item list-group-item-action border-0 rounded mb-2 text-start d-flex align-items-center transition-all" t-att-style="this.state.activeTab === 'dashboard' ? 'background-color: #0f172a; color: #ffffff;' : 'color: #4b5563; background-color: transparent;'">
                        <span class="me-3 d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-dashboard"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
                        </span>
                        Dashboard
                    </button>

                    <button t-on-click="() => this.switchTab('territory')" class="list-group-item list-group-item-action border-0 rounded mb-2 text-start d-flex align-items-center transition-all" t-att-style="this.state.activeTab === 'territory' ? 'background-color: #0f172a; color: #ffffff;' : 'color: #4b5563; background-color: transparent;'">
                        <span class="me-3 d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map"><path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z"/><path d="M15 5.764v15"/><path d="M9 3.236v15"/></svg>
                        </span>
                        Territory &amp; Routes
                    </button>

                    <button t-on-click="() => this.switchTab('warehouse')" class="list-group-item list-group-item-action border-0 rounded mb-2 text-start d-flex align-items-center transition-all" t-att-style="this.state.activeTab === 'warehouse' ? 'background-color: #0f172a; color: #ffffff;' : 'color: #4b5563; background-color: transparent;'">
                        <span class="me-3 d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-warehouse"><path d="M22 8.35V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8.35A2 2 0 0 1 3.26 6.5l8-3.2a2 2 0 0 1 1.48 0l8 3.2A2 2 0 0 1 22 8.35Z"/><path d="M6 18h12"/><path d="M6 14h12"/><rect width="12" height="12" x="6" y="10"/></svg>
                        </span>
                        Warehouse &amp; Stock
                    </button>

                    <button t-on-click="() => this.switchTab('operations')" class="list-group-item list-group-item-action border-0 rounded mb-2 text-start d-flex align-items-center transition-all" t-att-style="this.state.activeTab === 'operations' ? 'background-color: #0f172a; color: #ffffff;' : 'color: #4b5563; background-color: transparent;'">
                        <span class="me-3 d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.48 12H2"/></svg>
                        </span>
                        Operations Tracking
                    </button>

                    <button t-on-click="() => this.switchTab('financials')" class="list-group-item list-group-item-action border-0 rounded mb-2 text-start d-flex align-items-center transition-all" t-att-style="this.state.activeTab === 'financials' ? 'background-color: #0f172a; color: #ffffff;' : 'color: #4b5563; background-color: transparent;'">
                        <span class="me-3 d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-dollar-sign"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>
                        </span>
                        Financials
                    </button>

                    <button t-on-click="() => this.switchTab('schedules')" class="list-group-item list-group-item-action border-0 rounded mb-2 text-start d-flex align-items-center transition-all" t-att-style="this.state.activeTab === 'schedules' ? 'background-color: #0f172a; color: #ffffff;' : 'color: #4b5563; background-color: transparent;'">
                        <span class="me-3 d-flex align-items-center">
                           <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-days"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>
                        </span>
                        Schedules &amp; Targets
                    </button>

                    <hr class="my-2"/>

                    <button t-on-click="() => this.switchTab('staff')" class="list-group-item list-group-item-action border-0 rounded mb-2 text-start d-flex align-items-center transition-all" t-att-style="this.state.activeTab === 'staff' ? 'background-color: #0f172a; color: #ffffff;' : 'color: #4b5563; background-color: transparent;'">
                        <span class="me-3 d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        </span>
                        Staff Management
                    </button> 

                    <button t-on-click="() => this.switchTab('settings')" class="list-group-item list-group-item-action border-0 rounded mb-2 text-start d-flex align-items-center transition-all" t-att-style="this.state.activeTab === 'settings' ? 'background-color: #0f172a; color: #ffffff;' : 'color: #4b5563; background-color: transparent;'">
                        <span class="me-3 d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                        </span>
                        Settings
                    </button>
                </div>
            </div>

            <div class="flex-grow-1 p-5" style="overflow-y: auto;">

                <t t-if="this.state.activeTab === 'dashboard'">

                    <div class="mb-4 border-bottom pb-3 d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="h3 fw-bold text-dark mb-0">Command Center</h1>
                            <small class="text-muted">Real-time systemic overview of distribution operations.</small>
                        </div>
                        <div>
                            <span class="badge bg-success bg-opacity-10 text-white border border-success px-3 py-2 rounded-pill d-flex align-items-center shadow-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-radio me-2"><circle cx="12" cy="12" r="2"/><path d="M4.9 19.1a10 10 0 0 1 0-14.2"/><path d="M19.1 4.9a10 10 0 0 1 0 14.2"/><path d="M7.7 16.3a6 6 0 0 1 0-8.6"/><path d="M16.3 7.7a6 6 0 0 1 0 8.6"/></svg>
                                Live Data Feed Active
                            </span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card shadow-sm border-0 p-4 bg-white h-100 rounded-3" style="border-start: 4px solid #3b82f6 !important;">
                                <span class="text-muted text-uppercase small fw-bold">Today's Orders</span>
                                <h2 class="fw-bold text-dark mt-2 mb-0">184</h2>
                                <small class="text-success fw-bold mt-1 d-flex align-items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up me-1"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                                    12% vs Yesterday
                                </small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card shadow-sm border-0 p-4 bg-white h-100 rounded-3" style="border-start: 4px solid #10b981 !important;">
                                <span class="text-muted text-uppercase small fw-bold">Daily Revenue</span>
                                <h2 class="fw-bold text-dark mt-2 mb-0">Rs. 6.2M</h2>
                                <small class="text-success fw-bold mt-1 d-flex align-items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-circle me-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
                                    On Target
                                </small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card shadow-sm border-0 p-4 bg-white h-100 rounded-3" style="border-start: 4px solid #f59e0b !important;">
                                <span class="text-muted text-uppercase small fw-bold">Active Deliveries</span>
                                <h2 class="fw-bold text-dark mt-2 mb-0">42</h2>
                                <small class="text-muted mt-1">12 Pending | 30 In-Transit</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card shadow-sm border-0 p-4 bg-white h-100 rounded-3" style="border-start: 4px solid #6366f1 !important;">
                                <span class="text-muted text-uppercase small fw-bold">Active Field Staff</span>
                                <h2 class="fw-bold text-dark mt-2 mb-0">28 / 35</h2>
                                <small class="text-muted mt-1">Checked-in today</small>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-8">
                            <div class="card border-0 shadow-sm bg-white h-100 rounded-3">
                                <div class="p-3 border-bottom bg-light">
                                    <h6 class="mb-0 fw-bold text-dark d-flex align-items-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap text-warning me-2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                                        Recent Field Activity
                                    </h6>
                                </div>
                                <div class="list-group list-group-flush">
                                    <div class="list-group-item border-0 py-3 d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 38px; height: 38px; flex-shrink: 0;">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-cart"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between">
                                                <strong class="text-dark">New Order Generated</strong>
                                                <small class="text-muted">2 mins ago</small>
                                            </div>
                                            <small class="text-muted">Ali Khan booked an order of Rs. 45,000 at Bismillah General Store.</small>
                                        </div>
                                    </div>
                                    <div class="list-group-item border-0 py-3 d-flex align-items-center bg-light">
                                        <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 38px; height: 38px; flex-shrink: 0;">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between">
                                                <strong class="text-dark">Shop Check-in</strong>
                                                <small class="text-muted">15 mins ago</small>
                                            </div>
                                            <small class="text-muted">Usman Tariq checked into Madina Traders (Route B).</small>
                                        </div>
                                    </div>
                                    <div class="list-group-item border-0 py-3 d-flex align-items-center">
                                        <div class="bg-info text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 38px; height: 38px; flex-shrink: 0;">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-truck"><rect width="15" height="13" x="1" y="3" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between">
                                                <strong class="text-dark">Delivery Completed</strong>
                                                <small class="text-muted">1 hour ago</small>
                                            </div>
                                            <small class="text-muted">Kamran Ali completed manifest DLV-0093.</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm bg-white h-100 rounded-3">
                                <div class="p-3 border-bottom bg-light">
                                    <h6 class="mb-0 fw-bold text-danger d-flex align-items-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-triangle me-2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
                                        Critical Alerts
                                    </h6>
                                </div>
                                <div class="p-3">
                                    <div class="alert alert-danger border-0 shadow-sm mb-3 px-3 py-2 rounded-3">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3 text-danger">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-octagon"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                                            </div>
                                            <div>
                                                <strong class="d-block small">Credit Limit Exceeded</strong>
                                                <small>Al-Hafeez Supermart has utilized 98% of their limit.</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="alert alert-warning border-0 shadow-sm mb-0 px-3 py-2 text-dark rounded-3">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3 text-warning text-dark">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package-open"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                                            </div>
                                            <div>
                                                <strong class="d-block small">Low Stock Warning</strong>
                                                <small>Shahtaj Banaspati 5kg Tin is Out of Stock in Central Hub.</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm bg-white rounded-3">
                        <div class="p-3 border-bottom bg-light">
                            <h6 class="mb-0 fw-bold text-dark d-flex align-items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe text-secondary me-2"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                                Distribution Network Overview
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-md-3 border-end">
                                    <h3 class="fw-bold text-dark mb-0">3</h3>
                                    <span class="text-muted text-uppercase small fw-bold">Mapped Areas</span>
                                </div>
                                <div class="col-md-3 border-end">
                                    <h3 class="fw-bold text-dark mb-0">12</h3>
                                    <span class="text-muted text-uppercase small fw-bold">Active Routes</span>
                                </div>
                                <div class="col-md-3 border-end">
                                    <h3 class="fw-bold text-dark mb-0">145</h3>
                                    <span class="text-muted text-uppercase small fw-bold">Registered Shops</span>
                                </div>
                                <div class="col-md-3">
                                    <h3 class="fw-bold text-dark mb-0">2</h3>
                                    <span class="text-muted text-uppercase small fw-bold">Warehouses</span>
                                </div>
                            </div>
                        </div>
                    </div>

                </t>

                <t t-if="this.state.activeTab === 'territory'">
                    <TerritoryRoutes />
                </t>

                <t t-if="this.state.activeTab === 'warehouse'">
                    <WarehouseInventory />
                </t>

                <t t-if="this.state.activeTab === 'operations'">
                    <OperationsTracking />
                </t>

                <t t-if="this.state.activeTab === 'financials'">
                    <FinancialsInvoicing />
                </t>

                <t t-if="this.state.activeTab === 'staff'">
                    <StaffManagement />
                </t> 

                <t t-if="this.state.activeTab === 'settings'">
                    <PortalSettings />
                </t>  

                <t t-if="this.state.activeTab === 'schedules'">
                    <SchedulesTargets />
                </t>

            </div>
        </div>
    </t>
</templates>
