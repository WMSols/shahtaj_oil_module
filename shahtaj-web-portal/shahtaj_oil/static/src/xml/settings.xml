<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shahtaj_oil.PortalSettings" owl="1">
        <div class="card border-0 shadow-sm bg-white rounded-3">

            <div class="p-4 border-bottom bg-light d-flex justify-content-between align-items-center rounded-top">
                <div>
                    <h2 class="h4 fw-bold text-dark mb-0">General Settings</h2>
                    <small class="text-muted">Company profile, branding, and order booker GPS range.</small>
                </div>
                <span class="badge bg-dark px-3 py-2 fs-6 text-white">Admin</span>
            </div>

            <t t-if="this.state.isLoading">
                <div class="p-5 text-center text-muted">
                    <i class="fa fa-circle-o-notch fa-spin me-2"/> Loading settings...
                </div>
            </t>
            <t t-else="">
                <div class="p-4">
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="card border shadow-sm p-4 rounded-3 bg-white">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h5 class="fw-bold mb-1">Order Booker GPS Range</h5>
                                        <small class="text-muted">
                                            Check-in and place-order must be within this range of the shop pin.
                                            Changes apply immediately on the next GPS check.
                                        </small>
                                    </div>
                                    <span class="badge bg-dark text-white px-3 py-2">Live setting</span>
                                </div>
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-3">
                                        <label class="small fw-bold text-muted mb-1">Min distance (metres)</label>
                                        <input type="number" class="form-control" min="0" step="1"
                                               t-model="this.state.gpsForm.min_m"
                                               t-att-disabled="this.state.isSavingGps"/>
                                        <small class="text-muted">Use 0 for no minimum</small>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="small fw-bold text-muted mb-1">Max distance (metres)</label>
                                        <input type="number" class="form-control" min="10" step="1"
                                               t-model="this.state.gpsForm.max_m"
                                               t-att-disabled="this.state.isSavingGps"/>
                                        <small class="text-muted">Recommended 150–200 if 100 is too strict</small>
                                    </div>
                                    <div class="col-md-3">
                                        <button class="btn btn-dark fw-bold text-white px-4"
                                                t-on-click="saveGpsSettings"
                                                t-att-disabled="this.state.isSavingGps">
                                            <span t-if="this.state.isSavingGps" class="spinner-border spinner-border-sm me-2"/>
                                            Save GPS Range
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-7 border-end pe-4">
                            <h5 class="fw-bold mb-4">Company Profile</h5>

                            <div class="mb-3">
                                <label class="small fw-bold text-muted mb-1">Distributor Name (Appears on Invoices)</label>
                                <input type="text" class="form-control" t-model="this.state.companyForm.name"
                                       t-att-disabled="this.state.isSavingCompany"/>
                            </div>

                            <div class="mb-4">
                                <label class="small fw-bold text-muted mb-1">Primary Contact Number</label>
                                <input type="text" class="form-control" t-model="this.state.companyForm.phone"
                                       t-att-disabled="this.state.isSavingCompany"/>
                            </div>

                            <button class="btn btn-dark fw-bold px-4 text-white"
                                    t-on-click="saveCompanySettings"
                                    t-att-disabled="this.state.isSavingCompany">
                                <span t-if="this.state.isSavingCompany" class="spinner-border spinner-border-sm me-2"/>
                                Save Company Profile
                            </button>
                        </div>

                        <div class="col-md-5 ps-4">
                            <h5 class="fw-bold mb-4">Company Logo</h5>

                            <div class="p-4 border rounded-3 bg-light text-center shadow-sm">
                                <div class="mb-3">
                                    <t t-if="this.state.companyForm.logo_preview">
                                        <img t-att-src="this.state.companyForm.logo_preview"
                                             class="img-fluid rounded-3 border shadow-sm bg-white"
                                             style="max-height: 120px; object-fit: contain;"/>
                                    </t>
                                    <t t-else="">
                                        <div class="bg-white border rounded-3 d-inline-flex justify-content-center align-items-center shadow-sm"
                                             style="width: 120px; height: 120px;">
                                            <i class="fa fa-image fa-3x text-muted opacity-50"/>
                                        </div>
                                    </t>
                                </div>

                                <h6 class="fw-bold text-dark mb-1">Upload Logo</h6>
                                <small class="text-muted d-block mb-3">PNG or JPG, max 2 MB. Saved as soon as you choose a file.</small>

                                <input type="file" id="companyLogoInput" class="d-none"
                                       accept="image/png,image/jpeg"
                                       t-on-change="onLogoSelected"/>
                                <div class="d-flex flex-wrap justify-content-center gap-2">
                                    <label for="companyLogoInput"
                                           class="btn btn-sm btn-outline-dark fw-bold d-inline-flex align-items-center cursor-pointer mb-0"
                                           t-att-class="{'disabled': this.state.isSavingLogo}">
                                        <span t-if="this.state.isSavingLogo" class="spinner-border spinner-border-sm me-2"/>
                                        <i t-else="" class="fa fa-upload me-2"/>
                                        Choose Image
                                    </label>
                                    <button t-if="this.state.companyForm.logo_preview"
                                            class="btn btn-sm btn-outline-danger fw-bold"
                                            t-on-click="removeLogo"
                                            t-att-disabled="this.state.isSavingLogo">
                                        Remove
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
