<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Simplified product list for distributors -->
    <record id="view_shahtaj_product_list" model="ir.ui.view">
        <field name="name">product.template.list.shahtaj</field>
        <field name="model">product.template</field>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <list string="Products">
                <field name="name"/>
                <field name="shahtaj_sale_uom" string="Unit"/>
                <field name="standard_price" string="Cost"/>
                <field name="list_price" string="Sales Price"/>
                <field name="shahtaj_unit_margin" string="Profit/Unit" optional="show"/>
                <field name="shahtaj_margin_percent" string="Margin %" optional="show"/>
                <field name="taxes_id" widget="many2many_tags" string="Taxes" optional="show"/>
                <field name="qty_available" string="On Hand"/>
                <field name="shahtaj_qty_bookable" string="Available to Book"/>
                <field name="is_storable" string="Tracked" widget="boolean"/>
                <field name="active" widget="boolean_toggle" optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Simplified product form -->
    <record id="view_shahtaj_product_form" model="ir.ui.view">
        <field name="name">product.template.form.shahtaj</field>
        <field name="model">product.template</field>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <form string="Product">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Cheese Burger"/></h1>
                    </div>
                    <group>
                        <group string="Pricing">
                            <field name="standard_price" string="Cost Price"/>
                            <field name="list_price" string="Sales Price"/>
                            <field name="shahtaj_unit_margin" string="Profit per Unit" readonly="1"/>
                            <field name="shahtaj_margin_percent" string="Margin %" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Sales">
                            <field name="shahtaj_sale_uom" string="Selling Unit"/>
                            <field name="shahtaj_kg_per_unit"
                                   invisible="shahtaj_sale_uom in ('kg', 'ton')"
                                   required="shahtaj_sale_uom in ('litre', 'piece')"/>
                            <field name="taxes_id" widget="many2many_tags"
                                   string="Customer Taxes"
                                   force_save="1"
                                   domain="[('type_tax_use', '=', 'sale'), ('active', '=', True)]"
                                   context="{'default_type_tax_use': 'sale'}"/>
                        </group>
                    </group>
                    <group>
                        <group string="Inventory">
                            <field name="is_storable" string="Track Inventory"/>
                            <field name="invoice_policy" string="Invoice Policy"/>
                            <field name="qty_available" string="On Hand"
                                   readonly="not is_storable"/>
                            <field name="shahtaj_qty_bookable" string="Available to Book"
                                   readonly="1"/>
                            <field name="uom_id" readonly="1"/>
                        </group>
                        <group string="Sales Summary" invisible="not id">
                            <field name="shahtaj_qty_received" readonly="1"/>
                            <field name="shahtaj_qty_sold" readonly="1"/>
                            <field name="shahtaj_payable_to_manufacturer" readonly="1"/>
                        </group>
                    </group>
                    <group string="Optional">
                        <field name="barcode" placeholder="Scan or type barcode"/>
                        <field name="default_code" string="Internal Reference" optional="hide"/>
                    </group>
                    <field name="categ_id" invisible="1"/>
                    <field name="sale_ok" invisible="1"/>
                    <field name="purchase_ok" invisible="1"/>
                    <field name="type" invisible="1"/>
                    <field name="tracking" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Stock overview list -->
    <record id="view_shahtaj_product_stock_list" model="ir.ui.view">
        <field name="name">product.template.list.shahtaj.stock</field>
        <field name="model">product.template</field>
        <field name="priority">31</field>
        <field name="arch" type="xml">
            <list string="Stock Overview" create="false">
                <field name="name"/>
                <field name="shahtaj_qty_received" string="Received"/>
                <field name="shahtaj_qty_sold" string="Sold"/>
                <field name="qty_available" string="On Hand"/>
                <field name="shahtaj_qty_bookable" string="Available to Book"/>
                <field name="standard_price" string="Cost" optional="hide"/>
                <field name="shahtaj_payable_to_manufacturer" string="Payable" optional="show"/>
                <field name="virtual_available" string="Forecast" optional="hide"/>
                <field name="list_price" string="Price" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Manufacturer printable summary list -->
    <record id="view_shahtaj_manufacturer_summary_list" model="ir.ui.view">
        <field name="name">product.template.list.shahtaj.manufacturer</field>
        <field name="model">product.template</field>
        <field name="priority">32</field>
        <field name="arch" type="xml">
            <list string="Manufacturer Summary" create="false">
                <field name="name"/>
                <field name="shahtaj_sale_uom" string="Unit"/>
                <field name="standard_price" string="Cost/Unit"/>
                <field name="shahtaj_qty_received" string="Received"/>
                <field name="shahtaj_qty_sold" string="Delivered"/>
                <field name="qty_available" string="On Hand"/>
                <field name="shahtaj_payable_to_manufacturer" string="Payable to Manufacturer"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_product_search" model="ir.ui.view">
        <field name="name">product.template.search.shahtaj</field>
        <field name="model">product.template</field>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="barcode"/>
                <filter string="Tracked in Inventory" name="storable"
                        domain="[('is_storable', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_shahtaj_product_list" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_shahtaj_product_search"/>
        <field name="domain">[('sale_ok', '=', True), ('default_code', '!=', 'SHAHTAJ-LEGACY')]</field>
        <field name="context">{
            'shahtaj_simple_product': True,
            'default_sale_ok': True,
            'default_is_storable': True,
            'default_type': 'consu',
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No products yet
            </p>
            <p>
                Use <b>Quick Add Product</b> to create a product with cost, sales price,
                and optional opening stock.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_product_list_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_product_list"/>
        <field name="act_window_id" ref="action_shahtaj_product_list"/>
    </record>

    <record id="action_shahtaj_product_list_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_shahtaj_product_form"/>
        <field name="act_window_id" ref="action_shahtaj_product_list"/>
    </record>

    <record id="action_shahtaj_stock_overview" model="ir.actions.act_window">
        <field name="name">Stock Overview</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_shahtaj_product_search"/>
        <field name="domain">[('sale_ok', '=', True), ('is_storable', '=', True)]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No tracked products in stock
            </p>
            <p>
                Add products first, then use <b>Add Stock</b> to receive inventory.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_stock_overview_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_product_stock_list"/>
        <field name="act_window_id" ref="action_shahtaj_stock_overview"/>
    </record>

    <record id="action_shahtaj_stock_overview_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_shahtaj_product_form"/>
        <field name="act_window_id" ref="action_shahtaj_stock_overview"/>
    </record>

    <record id="action_shahtaj_manufacturer_summary" model="ir.actions.act_window">
        <field name="name">Manufacturer Summary</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_shahtaj_product_search"/>
        <field name="domain">[('sale_ok', '=', True), ('is_storable', '=', True)]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No products to report
            </p>
            <p>
                Shows received, delivered (to shops), and on-hand quantities per product, plus the amount
                payable to the manufacturer. Delivered updates when you use <b>Mark Delivery</b>.
                Select products and use <b>Print</b> to share with your manufacturer.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_manufacturer_summary_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_manufacturer_summary_list"/>
        <field name="act_window_id" ref="action_shahtaj_manufacturer_summary"/>
    </record>

    <!-- Full Odoo product form — optional advanced access -->
    <record id="action_shahtaj_product_advanced" model="ir.actions.act_window">
        <field name="name">Advanced Product Settings</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('sale_ok', '=', True), ('default_code', '!=', 'SHAHTAJ-LEGACY')]</field>
        <field name="context">{'default_is_storable': True}</field>
        <field name="help" type="html">
            <p>Full Odoo product form with all tabs (purchase, accounting, variants, etc.).</p>
        </field>
    </record>

</odoo>
