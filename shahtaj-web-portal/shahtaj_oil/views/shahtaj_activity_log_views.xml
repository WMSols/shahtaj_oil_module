<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_activity_log_list" model="ir.ui.view">
        <field name="name">shahtaj.activity.log.list</field>
        <field name="model">shahtaj.activity.log</field>
        <field name="arch" type="xml">
            <list string="Shahtaj Activity Logs" create="false" edit="false" delete="false" default_order="event_at desc">
                <field name="event_at"/>
                <field name="event_timezone" optional="show"/>
                <field name="status"/>
                <field name="source"/>
                <field name="operation"/>
                <field name="actor_user_id" optional="show"/>
                <field name="actor_role" optional="show"/>
                <field name="related_name" string="Related Record" optional="show"/>
                <field name="message" optional="show"/>
                <field name="request_ip" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_activity_log_form" model="ir.ui.view">
        <field name="name">shahtaj.activity.log.form</field>
        <field name="model">shahtaj.activity.log</field>
        <field name="arch" type="xml">
            <form string="Shahtaj Activity Log" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="What Happened">
                            <field name="name"/>
                            <field name="operation"/>
                            <field name="status"/>
                            <field name="source"/>
                            <field name="message"/>
                            <field name="error_details" invisible="status != 'failed'"/>
                        </group>
                        <group string="Who and When">
                            <field name="event_at"/>
                            <field name="event_date"/>
                            <field name="event_timezone"/>
                            <field name="actor_user_id"/>
                            <field name="actor_role"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Related Record">
                            <field name="related_model"/>
                            <field name="related_res_id"/>
                            <field name="related_name"/>
                        </group>
                        <group string="Request Details">
                            <field name="request_path"/>
                            <field name="request_method"/>
                            <field name="request_ip"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_shahtaj_activity_log_search" model="ir.ui.view">
        <field name="name">shahtaj.activity.log.search</field>
        <field name="model">shahtaj.activity.log</field>
        <field name="arch" type="xml">
            <search string="Search Activity Logs">
                <field name="name"/>
                <field name="operation"/>
                <field name="actor_user_id"/>
                <field name="status"/>
                <field name="source"/>
                <field name="event_timezone"/>
                <field name="related_model"/>
                <field name="related_name"/>
                <separator/>
                <filter name="failed" string="Failed Only" domain="[('status', '=', 'failed')]"/>
                <filter name="success" string="Success Only" domain="[('status', '=', 'success')]"/>
                <filter name="order_booker_api" string="Order Booker API" domain="[('source', '=', 'order_booker_api')]"/>
                <filter name="distributor_ui" string="Distributor UI" domain="[('source', '=', 'distributor_ui')]"/>
                <filter name="event_at" string="Event Time" date="event_at"/>
                <separator/>
                <filter name="group_status" string="Group by Status" context="{'group_by': 'status'}"/>
                <filter name="group_source" string="Group by Source" context="{'group_by': 'source'}"/>
                <filter name="group_operation" string="Group by Operation" context="{'group_by': 'operation'}"/>
                <filter name="group_user" string="Group by User" context="{'group_by': 'actor_user_id'}"/>
                <filter name="group_day" string="Group by Date" context="{'group_by': 'event_date'}"/>
                <filter name="group_timezone" string="Group by Timezone" context="{'group_by': 'event_timezone'}"/>
            </search>
        </field>
    </record>

    <record id="action_shahtaj_activity_logs" model="ir.actions.act_window">
        <field name="name">Activity Logs</field>
        <field name="res_model">shahtaj.activity.log</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_shahtaj_activity_log_list"/>
        <field name="search_view_id" ref="view_shahtaj_activity_log_search"/>
        <field name="context">{'search_default_failed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No activity logs yet</p>
            <p>
                This admin-only screen records important Shahtaj order booker,
                distributor, and system operations along with any captured errors.
            </p>
        </field>
    </record>

</odoo>
