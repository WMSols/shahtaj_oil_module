<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Customer invoices & credit notes — distributor list -->
    <record id="view_shahtaj_customer_invoice_list" model="ir.ui.view">
        <field name="name">account.move.list.shahtaj.customer</field>
        <field name="model">account.move</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <list string="Shop Invoices"
                  decoration-muted="state == 'cancel'"
                  decoration-info="move_type == 'out_refund'"
                  decoration-danger="payment_state == 'not_paid' and move_type == 'out_invoice' and state == 'posted'"
                  decoration-success="payment_state == 'paid' and move_type == 'out_invoice'">
                <field name="name" string="Number"/>
                <field name="invoice_date" string="Date"/>
                <field name="partner_id" string="Shop"/>
                <field name="move_type" string="Type" widget="badge"
                       decoration-info="move_type == 'out_refund'"
                       decoration-success="move_type == 'out_invoice'"/>
                <field name="payment_state" string="Payment"
                       widget="badge"
                       invisible="move_type == 'out_refund'"
                       decoration-danger="payment_state == 'not_paid'"
                       decoration-warning="payment_state == 'partial'"
                       decoration-success="payment_state in ('paid', 'in_payment')"/>
                <field name="state" string="Status" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'posted'"/>
                <field name="amount_total" string="Total"/>
                <field name="amount_residual" string="Due"/>
                <field name="shahtaj_is_legacy_balance" string="Opening" optional="show"/>
                <field name="reversed_entry_id" string="Reversal Of" optional="show"/>
                <field name="invoice_origin" string="Source" optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_customer_invoice_search" model="ir.ui.view">
        <field name="name">account.move.search.shahtaj.customer</field>
        <field name="model">account.move</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <search string="Shop Invoices">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="invoice_origin"/>
                <filter string="All Documents" name="all_documents"
                        domain="[('move_type', 'in', ('out_invoice', 'out_refund', 'out_receipt'))]"/>
                <filter string="Invoices" name="invoices_only"
                        domain="[('move_type', '=', 'out_invoice')]"/>
                <filter string="Credit Notes" name="credit_notes"
                        domain="[('move_type', '=', 'out_refund')]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Posted" name="posted" domain="[('state', '=', 'posted')]"/>
                <separator/>
                <filter string="Not Paid" name="not_paid"
                        domain="[('payment_state', '=', 'not_paid'), ('move_type', '=', 'out_invoice')]"/>
                <filter string="Partially Paid" name="partial"
                        domain="[('payment_state', '=', 'partial')]"/>
                <filter string="Paid" name="paid"
                        domain="[('payment_state', 'in', ('paid', 'in_payment'))]"/>
                <separator/>
                <filter string="Reversed Invoices" name="reversed"
                        domain="[('move_type', '=', 'out_invoice'), ('payment_state', '=', 'reversed')]"/>
                <filter string="Opening Balance" name="legacy_balance"
                        domain="[('shahtaj_is_legacy_balance', '=', True)]"/>
                <group>
                    <filter string="Shop" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'move_type'}"/>
                    <filter string="Payment Status" name="group_payment"
                            context="{'group_by': 'payment_state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'invoice_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Shop balances: accounting-focused list -->
    <record id="view_shahtaj_shop_balances_list" model="ir.ui.view">
        <field name="name">res.partner.list.shahtaj.shop.balances</field>
        <field name="model">res.partner</field>
        <field name="priority">2</field>
        <field name="arch" type="xml">
            <list string="Shop Balances"
                  decoration-danger="shahtaj_shop_category == 'credit' and credit_limit and outstanding_balance > credit_limit">
                <field name="name" string="Shop"/>
                <field name="owner_name" optional="show"/>
                <field name="owner_phone" optional="hide"/>
                <field name="registered_by_name" string="Registered By" optional="show"/>
                <field name="route_id" optional="show"/>
                <field name="shahtaj_shop_category" string="Category" widget="badge"
                       decoration-info="shahtaj_shop_category == 'cash'"
                       decoration-primary="shahtaj_shop_category == 'credit'"/>
                <field name="credit_limit" string="Credit Limit" optional="hide"/>
                <field name="outstanding_balance" string="Outstanding"/>
                <field name="credit" string="Receivable"
                       groups="account.group_account_invoice,account.group_account_readonly"/>
                <field name="total_invoiced" string="Total Invoiced" optional="show"
                       groups="account.group_account_invoice,account.group_account_readonly"/>
                <field name="use_partner_credit_limit" column_invisible="1"/>
                <field name="shahtaj_shop_category" column_invisible="1"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_shahtaj_shop_balances" model="ir.actions.act_window">
        <field name="name">Shop Balances</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('is_shahtaj_shop', '=', True),
            ('shop_approval_state', '=', 'approved'),
        ]</field>
        <field name="context">{'shahtaj_shop_form': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No approved shops yet
            </p>
            <p>
                Review each shop's credit limit, outstanding balance, and total invoiced.
                Open a shop to see sales orders, invoices, and payments.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_shop_balances_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_shop_balances_list"/>
        <field name="act_window_id" ref="action_shahtaj_shop_balances"/>
    </record>

    <record id="action_shahtaj_shop_balances_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_shahtaj_shop_form"/>
        <field name="act_window_id" ref="action_shahtaj_shop_balances"/>
    </record>

    <!-- Field sales orders (from shop visits) -->
    <record id="action_shahtaj_field_sales_orders" model="ir.actions.act_window">
        <field name="name">Field Sales Orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form,kanban,pivot,graph</field>
        <field name="domain">[('shahtaj_visit_id', '!=', False)]</field>
        <field name="context">{'search_default_sales': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No field orders yet
            </p>
            <p>
                Orders appear here when order bookers place orders during shop visits.
                Create invoices from confirmed orders, then register customer payments.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_orders_to_deliver" model="ir.actions.act_window">
        <field name="name">Orders to Deliver</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('shahtaj_visit_id', '!=', False),
            ('state', 'in', ('sale', 'done')),
            ('shahtaj_delivery_status', 'in', ('pending', 'partial')),
        ]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No deliveries waiting
            </p>
            <p>
                Open an order and click <b>Mark Delivery</b> (or the list <b>Deliver</b> button)
                to ship full or partial quantity. Stock on hand and Delivered qty update automatically.
                Then invoice from <b>Orders to Invoice</b> (delivered quantities).
            </p>
        </field>
    </record>

    <record id="action_shahtaj_orders_to_invoice" model="ir.actions.act_window">
        <field name="name">Orders to Invoice</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('shahtaj_visit_id', '!=', False),
            ('invoice_status', '=', 'to invoice'),
        ]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No field orders waiting for invoice
            </p>
            <p>
                Products use <b>Delivered quantities</b> invoicing.
                Mark delivery first, then use <b>Create Invoice → Regular</b>.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_customer_invoices" model="ir.actions.act_window">
        <field name="name">Customer Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[
            ('move_type', 'in', ('out_invoice', 'out_refund', 'out_receipt')),
            ('partner_id.is_shahtaj_shop', '=', True),
        ]</field>
        <field name="context">{
            'default_move_type': 'out_invoice',
            'search_default_all_documents': 1,
        }</field>
        <field name="search_view_id" ref="view_shahtaj_customer_invoice_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No customer invoices yet
            </p>
            <p>
                Invoices and credit notes for retail shops. Use <b>Regular invoice</b>
                from field sales orders. Credit notes appear here after you reverse an invoice.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_customer_invoices_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_customer_invoice_list"/>
        <field name="act_window_id" ref="action_shahtaj_customer_invoices"/>
    </record>

    <record id="action_shahtaj_credit_notes" model="ir.actions.act_window">
        <field name="name">Credit Notes</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('move_type', '=', 'out_refund'),
            ('partner_id.is_shahtaj_shop', '=', True),
        ]</field>
        <field name="context">{
            'default_move_type': 'out_refund',
            'search_default_credit_notes': 1,
        }</field>
        <field name="search_view_id" ref="view_shahtaj_customer_invoice_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No credit notes yet
            </p>
            <p>
                Credit notes reduce what a shop owes (returns, corrections).
                Create them from a posted invoice using <b>Credit Note</b>.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_credit_notes_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_customer_invoice_list"/>
        <field name="act_window_id" ref="action_shahtaj_credit_notes"/>
    </record>

    <record id="action_shahtaj_opening_balance_invoices" model="ir.actions.act_window">
        <field name="name">Opening Balance Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('move_type', '=', 'out_invoice'),
            ('partner_id.is_shahtaj_shop', '=', True),
            ('shahtaj_is_legacy_balance', '=', True),
        ]</field>
        <field name="context">{
            'default_move_type': 'out_invoice',
            'create': False,
        }</field>
        <field name="search_view_id" ref="view_shahtaj_customer_invoice_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No opening balance invoices yet
            </p>
            <p>
                These are created when a shop is approved with a <b>Legacy Balance</b>
                (previous debt). Open an invoice and use <b>Register Payment</b> to collect.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_opening_balance_invoices_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_customer_invoice_list"/>
        <field name="act_window_id" ref="action_shahtaj_opening_balance_invoices"/>
    </record>

    <record id="action_shahtaj_customer_payments" model="ir.actions.act_window">
        <field name="name">Customer Payments</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="view_id" ref="view_account_payment_tree_shahtaj"/>
        <field name="domain">[
            ('partner_type', '=', 'customer'),
            '|', '|',
            ('partner_id.is_shahtaj_shop', '=', True),
            ('partner_id.parent_id.is_shahtaj_shop', '=', True),
            ('partner_id.commercial_partner_id.is_shahtaj_shop', '=', True),
        ]</field>
        <field name="context">{
            'default_payment_type': 'inbound',
            'default_partner_type': 'customer',
            'search_default_inbound_filter': 1,
            'default_move_journal_types': ('bank', 'cash'),
            'display_account_trust': True,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record a customer payment
            </p>
            <p>Register payments collected from shops against their invoices.</p>
        </field>
    </record>

    <!-- Menus: see shahtaj_menus.xml (hub) and shahtaj_accounting_hub_views.xml -->

</odoo>
