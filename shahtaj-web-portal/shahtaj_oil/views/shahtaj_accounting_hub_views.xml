<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_accounting_hub_form" model="ir.ui.view">
        <field name="name">shahtaj.accounting.hub.form</field>
        <field name="model">shahtaj.accounting.hub</field>
        <field name="arch" type="xml">
            <form string="Shop Accounting" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1>Shop Accounting</h1>
                        <p class="text-muted">
                            Bill shops for field orders, record payments, and issue credit notes for returns.
                        </p>
                    </div>
                    <group string="Overview">
                        <group>
                            <field name="field_order_count" readonly="1"/>
                            <field name="orders_to_deliver_count" readonly="1"/>
                            <field name="orders_to_invoice_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="open_invoice_count" readonly="1"/>
                            <field name="credit_note_count" readonly="1"/>
                            <field name="shop_count" readonly="1"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>Typical workflow</strong>
                        <ol class="mb-0 mt-2">
                            <li>Order bookers place orders during shop visits.</li>
                            <li>Mark <b>Delivery</b> (full or partial) so stock leaves the warehouse.</li>
                            <li>Create a <b>Regular invoice</b> for delivered quantities.</li>
                            <li>Record payments on the invoice (partial payments are allowed).</li>
                            <li>For returns, open a posted invoice → <b>Credit Note</b> → post the credit note.</li>
                            <li>Review each shop's balance under Shop Balances.</li>
                        </ol>
                    </div>
                    <group string="Open a section">
                        <group string="Step 1 — Sales">
                            <button name="action_open_field_sales_orders" type="object"
                                    string="Field Sales Orders"
                                    class="btn btn-primary mb-2"
                                    icon="fa-shopping-cart"/>
                            <button name="action_open_orders_to_deliver" type="object"
                                    string="Orders to Deliver"
                                    class="btn btn-secondary mb-2"
                                    icon="fa-truck"/>
                            <button name="action_open_orders_to_invoice" type="object"
                                    string="Orders to Invoice"
                                    class="btn btn-secondary mb-2"
                                    icon="fa-file-text-o"/>
                        </group>
                        <group string="Step 2 — Billing &amp; Returns">
                            <button name="action_open_customer_invoices" type="object"
                                    string="Invoices &amp; Credit Notes"
                                    class="btn btn-primary mb-2"
                                    icon="fa-pencil-square-o"/>
                            <button name="action_open_credit_notes" type="object"
                                    string="Credit Notes Only"
                                    class="btn btn-secondary mb-2"
                                    icon="fa-undo"/>
                            <button name="action_open_opening_balance_invoices" type="object"
                                    string="Opening Balance Invoices"
                                    class="btn btn-secondary mb-2"
                                    icon="fa-bookmark"/>
                            <button name="action_open_customer_payments" type="object"
                                    string="Customer Payments"
                                    class="btn btn-secondary mb-2"
                                    icon="fa-money"/>
                        </group>
                    </group>
                    <group>
                        <group string="Step 3 — Shop balances">
                            <button name="action_open_shop_balances" type="object"
                                    string="Shop Balances"
                                    class="btn btn-primary mb-2"
                                    icon="fa-balance-scale"/>
                        </group>
                        <group string="Step 4 — Profit">
                            <button name="action_open_pnl_dashboard" type="object"
                                    string="Profit &amp; Loss Dashboard"
                                    class="btn btn-primary"
                                    icon="fa-line-chart"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shahtaj_accounting_hub" model="ir.actions.server">
        <field name="name">Shop Accounting</field>
        <field name="model_id" ref="model_shahtaj_accounting_hub"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_accounting_hub()</field>
    </record>

</odoo>
