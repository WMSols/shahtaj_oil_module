<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_shahtaj_manufacturer_summary" model="ir.actions.report">
        <field name="name">Manufacturer Stock Summary</field>
        <field name="model">shahtaj.manufacturer.summary</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">shahtaj_oil.report_manufacturer_summary</field>
        <field name="report_file">shahtaj_oil.report_manufacturer_summary</field>
        <field name="print_report_name">'Manufacturer Summary - %s to %s' % (object.date_from, object.date_to)</field>
    </record>

    <template id="report_manufacturer_summary">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="summary">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Manufacturer Stock Summary</h2>
                        <p>
                            Period:
                            <span t-field="summary.date_from"/>
                            to
                            <span t-field="summary.date_to"/>
                        </p>
                        <p class="text-muted">
                            Received and delivered quantities are for the selected period.
                            Stock value on hand uses weighted average receipt cost.
                        </p>
                        <table class="table table-sm table-bordered mt-3">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-end">Avg Cost</th>
                                    <th class="text-end">Received</th>
                                    <th class="text-end">Purchased (period)</th>
                                    <th class="text-end">Delivered</th>
                                    <th class="text-end">On Hand</th>
                                    <th class="text-end">Stock Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="summary.line_ids" t-as="line">
                                    <td><span t-field="line.product_id.name"/></td>
                                    <td class="text-end">
                                        <span t-field="line.avg_unit_cost"
                                              t-options="{'widget': 'monetary', 'display_currency': summary.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="'%.2f' % line.qty_received"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.purchase_value_period"
                                              t-options="{'widget': 'monetary', 'display_currency': summary.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="'%.2f' % line.qty_delivered"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="'%.2f' % line.qty_on_hand"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.stock_value_on_hand"
                                              t-options="{'widget': 'monetary', 'display_currency': summary.currency_id}"/>
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot t-if="summary.line_ids">
                                <tr>
                                    <th colspan="2" class="text-end">Period Totals</th>
                                    <th class="text-end">
                                        <span t-esc="'%.2f' % summary.total_received_qty"/>
                                    </th>
                                    <th class="text-end">
                                        <span t-field="summary.total_purchase_value_period"
                                              t-options="{'widget': 'monetary', 'display_currency': summary.currency_id}"/>
                                    </th>
                                    <th class="text-end">
                                        <span t-esc="'%.2f' % summary.total_delivered_qty"/>
                                    </th>
                                    <th class="text-end">
                                        <span t-esc="'%.2f' % summary.total_on_hand_qty"/>
                                    </th>
                                    <th class="text-end">
                                        <span t-field="summary.total_stock_value_on_hand"
                                              t-options="{'widget': 'monetary', 'display_currency': summary.currency_id}"/>
                                    </th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
