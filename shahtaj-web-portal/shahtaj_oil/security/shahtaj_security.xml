<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="res.groups.privilege" id="res_groups_privilege_shahtaj">
        <field name="name">Shahtaj Order Booker</field>
        <field name="sequence">5</field>
        <field name="category_id" ref="base.module_category_sales"/>
        <field name="placeholder">No</field>
    </record>

    <record id="group_shahtaj_distributor" model="res.groups">
        <field name="name">Distributor</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_shahtaj"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Distributor role: operations access. Financials require the Financial Access toggle.</field>
    </record>

    <record id="group_shahtaj_distributor_financial" model="res.groups">
        <field name="name">Distributor Financial Access</field>
        <field name="sequence">11</field>
        <field name="privilege_id" ref="res_groups_privilege_shahtaj"/>
        <field name="comment">Technical: invoices, payments, P&amp;L, bank/cash, and product pricing.</field>
    </record>

    <!-- Native Odoo apps (Sales, Inventory, Accounting, …) — only for native-UI distributors -->
    <record id="group_shahtaj_distributor_native_apps" model="res.groups">
        <field name="name">Distributor Native Odoo Apps</field>
        <field name="implied_ids" eval="[
            (4, ref('product.group_product_manager')),
            (4, ref('stock.group_stock_manager')),
            (4, ref('sales_team.group_sale_manager')),
            (4, ref('account.group_account_invoice')),
            (4, ref('account.group_account_readonly')),
        ]"/>
        <field name="comment">Technical: exposes standard Odoo application menus for native-UI distributors.</field>
    </record>

    <!-- Native Shahtaj menus (zones, routes, shops, …) — hidden when custom portal is enabled -->
    <record id="group_shahtaj_native_distributor_ui" model="res.groups">
        <field name="name">Distributor Native Shahtaj Menus</field>
        <field name="comment">Technical: standard Shahtaj backend menus for native-UI distributors.</field>
    </record>

    <!-- OWL distributor portal only — assigned when user.shahtaj_custom_frontend is True -->
    <record id="group_shahtaj_custom_portal_user" model="res.groups">
        <field name="name">Distributor Custom Portal</field>
        <field name="comment">Technical: OWL distributor portal UI only (no native Odoo / Shahtaj menus).</field>
    </record>

    <record id="group_shahtaj_order_booker" model="res.groups">
        <field name="name">Order Booker</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_shahtaj"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Field booker: visits, GPS check-in, tasks, shop registration.</field>
    </record>
</odoo>
